# ============================================================
# JenPark Backend — Environment Configuration Template
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
# Local:   mongodb://localhost:27017/jenpark
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/jenpark?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/jenpark

# -----------------------------------------------------------
# JWT
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------
# AWS S3 (file/media uploads via multer)
# Leave blank to disable S3 integration during local dev
# -----------------------------------------------------------
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=
AWS_REGION=ap-south-1

# -----------------------------------------------------------
# CORS
# For production set to your frontend origin, e.g. https://app.jenpark.io
# -----------------------------------------------------------
CORS_ORIGIN=*

# -----------------------------------------------------------
# Logging  (error | warn | info | http | verbose | debug | silly)
# -----------------------------------------------------------
LOG_LEVEL=info
