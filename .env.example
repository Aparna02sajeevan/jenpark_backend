# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Database
MONGO_URI=mongodb://localhost:27017/jenpark

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=
AWS_REGION=

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
